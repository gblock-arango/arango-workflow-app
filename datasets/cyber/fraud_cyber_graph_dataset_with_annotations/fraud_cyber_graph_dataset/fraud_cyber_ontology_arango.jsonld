  "@id": "ex:FraudCyberPropertyGraphOntology",
  "@type": "owl:Ontology",
  "label": "Fraud/Cyber Property Graph Ontology for ArangoDB",
  "description": "Ontology aligned to the synthetic ArangoDB property graph dataset containing accounts, transactions, devices, IP addresses, attack patterns, fraud signals, and typed edges.",
  "arangodb:graphName": "fraud_cyber_graph",
  "arangodb:edgeCollection": "edges",
  "arangodb:vertexCollections": [
    "accounts",
    "transactions",
    "devices",
    "ips",
    "attack_patterns",
    "fraud_signals"
  ],
  "edgeDefinitions": [
    {
      "predicate": "initiated",
      "edgeCollection": "edges",
      "fromCollections": [
        "accounts"
      ],
      "toCollections": [
        "transactions"
      ]
    },
    {
      "predicate": "hasUsedDevice",
      "edgeCollection": "edges",
      "fromCollections": [
        "accounts"
      ],
      "toCollections": [
        "devices"
      ]
    },
    {
      "predicate": "hasUsedIP",
      "edgeCollection": "edges",
      "fromCollections": [
        "accounts"
      ],
      "toCollections": [
        "ips"
      ]
    },
    {
      "predicate": "usedDevice",
      "edgeCollection": "edges",
      "fromCollections": [
        "transactions"
      ],
      "toCollections": [
        "devices"
      ]
    },
    {
      "predicate": "originatedFrom",
      "edgeCollection": "edges",
      "fromCollections": [
        "transactions"
      ],
      "toCollections": [
        "ips"
      ]
    },
    {
      "predicate": "matchesPattern",
      "edgeCollection": "edges",
      "fromCollections": [
        "transactions"
      ],
      "toCollections": [
        "attack_patterns"
      ]
    },
    {
      "predicate": "triggeredSignal",
      "edgeCollection": "edges",
      "fromCollections": [
        "transactions"
      ],
      "toCollections": [
        "fraud_signals"
      ]
    }
  ],
  "@graph": [
    {
      "@id": "ex:Account",
      "@type": "Class",
      "label": "Account",
      "collection": "accounts",
      "documentCount": 30,
      "description": "Customer or user account initiating transactions."
    },
    {
      "@id": "ex:Transaction",
      "@type": "Class",
      "label": "Transaction",
      "collection": "transactions",
      "documentCount": 100,
      "description": "Payment, transfer, withdrawal, or other account activity."
    },
    {
      "@id": "ex:Device",
      "@type": "Class",
      "label": "Device",
      "collection": "devices",
      "documentCount": 10,
      "description": "Endpoint or browser/mobile device used to conduct transactions."
    },
    {
      "@id": "ex:IPAddress",
      "@type": "Class",
      "label": "IPAddress",
      "collection": "ips",
      "documentCount": 20,
      "description": "Network origin observed during account or transaction activity."
    },
    {
      "@id": "ex:AttackPattern",
      "@type": "Class",
      "label": "AttackPattern",
      "collection": "attack_patterns",
      "documentCount": 5,
      "description": "Fraud or cyber behavior pattern matched by transaction activity."
    },
    {
      "@id": "ex:FraudSignal",
      "@type": "Class",
      "label": "FraudSignal",
      "collection": "fraud_signals",
      "documentCount": 19,
      "description": "Risk signal generated from transaction, device, IP, and pattern evidence."
    },
    {
      "@id": "ex:initiated",
      "@type": "ObjectProperty",
      "label": "initiated",
      "domain": "ex:Account",
      "range": "ex:Transaction",
      "edgeCollection": "edges",
      "description": "An account initiated a transaction.",
      "arangodb:edgeProperties": {
        "timestamp": "xsd:dateTime"
      }
    },
    {
      "@id": "ex:hasUsedDevice",
      "@type": "ObjectProperty",
      "label": "hasUsedDevice",
      "domain": "ex:Account",
      "range": "ex:Device",
      "edgeCollection": "edges",
      "description": "An account has historically used a device.",
      "arangodb:edgeProperties": {
        "firstSeen": "xsd:dateTime"
      }
    },
    {
      "@id": "ex:hasUsedIP",
      "@type": "ObjectProperty",
      "label": "hasUsedIP",
      "domain": "ex:Account",
      "range": "ex:IPAddress",
      "edgeCollection": "edges",
      "description": "An account has historically used an IP address.",
      "arangodb:edgeProperties": {
        "lastSeen": "xsd:dateTime"
      }
    },
    {
      "@id": "ex:usedDevice",
      "@type": "ObjectProperty",
      "label": "usedDevice",
      "domain": "ex:Transaction",
      "range": "ex:Device",
      "edgeCollection": "edges",
      "description": "A transaction used a device.",
      "arangodb:edgeProperties": {
        "isNewDeviceForAccount": "xsd:boolean"
      }
    },
    {
      "@id": "ex:originatedFrom",
      "@type": "ObjectProperty",
      "label": "originatedFrom",
      "domain": "ex:Transaction",
      "range": "ex:IPAddress",
      "edgeCollection": "edges",
      "description": "A transaction originated from an IP address.",
      "arangodb:edgeProperties": {
        "ipThreatScore": "xsd:decimal"
      }
    },
    {
      "@id": "ex:matchesPattern",
      "@type": "ObjectProperty",
      "label": "matchesPattern",
      "domain": "ex:Transaction",
      "range": "ex:AttackPattern",
      "edgeCollection": "edges",
      "description": "A transaction matched a fraud or cyber attack pattern.",
      "arangodb:edgeProperties": {
        "confidence": "xsd:decimal"
      }
    },
    {
      "@id": "ex:triggeredSignal",
      "@type": "ObjectProperty",
      "label": "triggeredSignal",
      "domain": "ex:Transaction",
      "range": "ex:FraudSignal",
      "edgeCollection": "edges",
      "description": "A transaction triggered a fraud signal.",
      "arangodb:edgeProperties": {
        "riskScore": "xsd:decimal"
      }
    },
    {
      "@id": "ex:Account._key",
      "@type": "DatatypeProperty",
      "label": "_key",
      "domain": "ex:Account",
      "range": "xsd:string"
    },
    {
      "@id": "ex:Account.@id",
      "@type": "DatatypeProperty",
      "label": "@id",
      "domain": "ex:Account",
      "range": "xsd:anyURI"
    },
    {
      "@id": "ex:Account.@type",
      "@type": "DatatypeProperty",
      "label": "@type",
      "domain": "ex:Account",
      "range": "xsd:string"
    },
    {
      "@id": "ex:Account.accountId",
      "@type": "DatatypeProperty",
      "label": "accountId",
      "domain": "ex:Account",
      "range": "xsd:string"
    },
    {
      "@id": "ex:Account.accountType",
      "@type": "DatatypeProperty",
      "label": "accountType",
      "domain": "ex:Account",
      "range": "xsd:string"
    },
    {
      "@id": "ex:Account.country",
      "@type": "DatatypeProperty",
      "label": "country",
      "domain": "ex:Account",
      "range": "xsd:string"
    },
    {
      "@id": "ex:Account.status",
      "@type": "DatatypeProperty",
      "label": "status",
      "domain": "ex:Account",
      "range": "xsd:string"
    },
    {
      "@id": "ex:Account.baselineRisk",
      "@type": "DatatypeProperty",
      "label": "baselineRisk",
      "domain": "ex:Account",
      "range": "xsd:decimal"
    },
    {
      "@id": "ex:Account.createdAt",
      "@type": "DatatypeProperty",
      "label": "createdAt",
      "domain": "ex:Account",
      "range": "xsd:dateTime"
    },
    {
      "@id": "ex:Transaction._key",
      "@type": "DatatypeProperty",
      "label": "_key",
      "domain": "ex:Transaction",
      "range": "xsd:string"
    },
    {
      "@id": "ex:Transaction.@id",
      "@type": "DatatypeProperty",
      "label": "@id",
      "domain": "ex:Transaction",
      "range": "xsd:anyURI"
    },
    {
      "@id": "ex:Transaction.@type",
      "@type": "DatatypeProperty",
      "label": "@type",
      "domain": "ex:Transaction",
      "range": "xsd:string"
    },
    {
      "@id": "ex:Transaction.transactionId",
      "@type": "DatatypeProperty",
      "label": "transactionId",
      "domain": "ex:Transaction",
      "range": "xsd:string"
    },
    {
      "@id": "ex:Transaction.amount",
      "@type": "DatatypeProperty",
      "label": "amount",
      "domain": "ex:Transaction",
      "range": "xsd:decimal"
    },
    {
      "@id": "ex:Transaction.currency",
      "@type": "DatatypeProperty",
      "label": "currency",
      "domain": "ex:Transaction",
      "range": "xsd:string"
    },
    {
      "@id": "ex:Transaction.timestamp",
      "@type": "DatatypeProperty",
      "label": "timestamp",
      "domain": "ex:Transaction",
      "range": "xsd:dateTime"
    },
    {
      "@id": "ex:Transaction.channel",
      "@type": "DatatypeProperty",
      "label": "channel",
      "domain": "ex:Transaction",
      "range": "xsd:string"
    },
    {
      "@id": "ex:Transaction.merchantCategory",
      "@type": "DatatypeProperty",
      "label": "merchantCategory",
      "domain": "ex:Transaction",
      "range": "xsd:string"
    },
    {
      "@id": "ex:Transaction.decision",
      "@type": "DatatypeProperty",
      "label": "decision",
      "domain": "ex:Transaction",
      "range": "xsd:string"
    },
    {
      "@id": "ex:Transaction.isFraud",
      "@type": "DatatypeProperty",
      "label": "isFraud",
      "domain": "ex:Transaction",
      "range": "xsd:boolean"
    },
    {
      "@id": "ex:Device._key",
      "@type": "DatatypeProperty",
      "label": "_key",
      "domain": "ex:Device",
      "range": "xsd:string"
    },
    {
      "@id": "ex:Device.@id",
      "@type": "DatatypeProperty",
      "label": "@id",
      "domain": "ex:Device",
      "range": "xsd:anyURI"
    },
    {
      "@id": "ex:Device.@type",
      "@type": "DatatypeProperty",
      "label": "@type",
      "domain": "ex:Device",
      "range": "xsd:string"
    },
    {
      "@id": "ex:Device.deviceId",
      "@type": "DatatypeProperty",
      "label": "deviceId",
