      "domain": "ex:edges",
      "range": "xsd:decimal"
    },
    {
      "@id": "ex:annotation",
      "@type": "rdf:Property",
      "name": "annotation",
      "description": "Natural-language explanation attached to every vertex and edge, summarizing the entity or relationship role and analytic impact.",
      "domainIncludes": [
        "Account",
        "Transaction",
        "Device",
        "IPAddress",
        "AttackPattern",
        "FraudSignal",
        "GraphEdge"
      ],
      "rangeIncludes": "xsd:string",
      "arangoProperty": "annotation"
    }
  ],
  "annotationPolicy": {
    "property": "annotation",
    "appliesTo": [
      "accounts",
      "transactions",
      "devices",
      "ips",
      "attack_patterns",
      "fraud_signals",
      "edges"
    ],
    "purpose": "Natural-language summary of each vertex or edge role, fraud/cyber relevance, and expected impact in property-graph analytics and GraphRAG grounding.",
    "storage": "Stored as a normal ArangoDB document attribute on every vertex and edge document."
  }
}