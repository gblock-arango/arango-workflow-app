    },
    {
      "@id": "ex:Device.isEmulator",
      "@type": "DatatypeProperty",
      "label": "isEmulator",
      "domain": "ex:Device",
      "range": "xsd:boolean"
    },
    {
      "@id": "ex:Device.firstSeen",
      "@type": "DatatypeProperty",
      "label": "firstSeen",
      "domain": "ex:Device",
      "range": "xsd:dateTime"
    },
    {
      "@id": "ex:IPAddress._key",
      "@type": "DatatypeProperty",
      "label": "_key",
      "domain": "ex:IPAddress",
      "range": "xsd:string"
    },
    {
