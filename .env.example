# =============================================================================
# Arango-OntoExtract (AOE) — Environment Configuration
# Copy this file to .env and fill in your values.
# =============================================================================

# -- Deployment Mode -----------------------------------------------------------
# Controls which ArangoDB connection profile is active and which features
# are available (GAE, SmartGraphs, SatelliteCollections, etc.).
#
# Options:
#   local_docker           — Single ArangoDB server in Docker (no GAE, no SSL)
#   self_managed_platform  — Remote ArangoDB cluster (GAE enabled, SSL, Enterprise)
#   managed_platform       — ArangoDB Managed Platform / AMP (requires ArangoDB 4.0+)
#
TEST_DEPLOYMENT_MODE=local_docker

# -- Databricks Apps (deployed) — peer URLs via Unity Catalog -----------------
# Required on the App and for ./deploy_app.sh / ./scripts/read_uc_peer_registry.sh
# DATABRICKS_SQL_WAREHOUSE_ID=473d40703241ee4c
# ARANGO_GATEWAY_REGISTRY_TABLE=workspace.default.arango_gateway_registry
# ARANGO_AGENT_REGISTRY_TABLE=workspace.default.arango_agent_registry
# ARANGO_REGISTRY_TABLE=workspace.default.arango_connection_registry
# Optional overrides (else read active row from UC):
# ARANGO_GATEWAY_BASE_URL=https://arango-gateway-app-….databricksapps.com
# ARANGO_AGENT_BASE_URL=https://mcp-arango-agent-….databricksapps.com
# Local check: PYTHONPATH=src python scripts/print_effective_peer_urls.py

# -- ArangoDB (local_docker) — legacy; production uses gateway only ------------
# ARANGO_HOST is not used when get_db() goes through arango-gateway-app.
ARANGO_HOST=http://localhost:8530
ARANGO_DB=OntoExtract
ARANGO_USER=root
ARANGO_PASSWORD=changeme
ARANGO_NO_AUTH=false

# -- ArangoDB (self_managed_platform) ------------------------------------------
# Uncomment when TEST_DEPLOYMENT_MODE=self_managed_platform:
# ARANGO_ENDPOINT=https://your-cluster-host:8529
# ARANGO_DB=OntoExtract
# ARANGO_USER=root
# ARANGO_PASSWORD=your-cluster-password
# ARANGO_VERIFY_SSL=true
# ARANGO_TIMEOUT=30

# -- ArangoDB (managed_platform / AMP) ----------------------------------------
# Uncomment when TEST_DEPLOYMENT_MODE=managed_platform (requires ArangoDB 4.0+):
# GAE_DEPLOYMENT_MODE=amp
# ARANGO_ENDPOINT=https://your-deployment.arangodb.cloud:8529
# ARANGO_DB=your-db
# ARANGO_USER=root
# ARANGO_PASSWORD=your-db-password
# ARANGO_GRAPH_API_KEY_ID=your-api-key-id
# ARANGO_GRAPH_API_KEY_SECRET=your-api-key-secret
# ARANGO_VERIFY_SSL=true
# ARANGO_TIMEOUT=30

# -- Public HTTP path (Arango Container Manager / pilot) -----------------------
# Single variable for FastAPI *and* Next.js: same prefix (no trailing slash).
# Backend: SERVICE_URL_PATH_PREFIX → Settings.service_url_path_prefix
# Frontend: next.config.js loads repo .env and sets NEXT_PUBLIC_BASE_PATH + basePath from this.
# Example:
# SERVICE_URL_PATH_PREFIX=/_service/uds/_db/ontoextract/arango-ontoextract
# SERVICE_URL_PATH_PREFIX=

# Bundled UI (optional): ``make package-arango-manual-all`` runs ``npm ci && next build``
# with ``AOE_STATIC_EXPORT=1`` and copies ``frontend/out`` into the tarball.
# Requires SERVICE_URL_PATH_PREFIX (in .env or exported) and Node/npm.
# Next middleware does not run on static HTML.

# -- Redis (task queue) --------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
# Pilot / API-only pods: point REDIS_URL at a reachable Redis, or set RATE_LIMIT_ENABLED=false
# if you have no Redis (rate limiting degrades gracefully but still prefers a real URL).

# -- LLM Providers -------------------------------------------------------------
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
# Optional: custom OpenAI-compatible API base (default: official OpenAI)
OPENAI_BASE_URL=

# Primary model for ontology extraction
LLM_EXTRACTION_MODEL=claude-sonnet-4-20250514
# Embedding model for chunks and entity resolution
EMBEDDING_MODEL=text-embedding-3-small

# -- Application ---------------------------------------------------------------
APP_ENV=development
APP_LOG_LEVEL=INFO
# IMPORTANT: Set to a strong random value in production (min 32 chars)
APP_SECRET_KEY=change-this-to-a-random-string

# Backend
BACKEND_HOST=0.0.0.0
# Default 8010 avoids clashing with other apps on 8000. Must match BACKEND_PROXY_URL (frontend) if you use the dev proxy.
BACKEND_PORT=8010
BACKEND_WORKERS=1

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000

# When true, FastAPI registers RateLimitMiddleware (see app/api/rate_limit.py)
RATE_LIMIT_ENABLED=true

# Frontend: omit NEXT_PUBLIC_API_URL in dev so the UI uses same-origin /api/* (rewritten by Next to BACKEND_PROXY_URL).
# Or set explicitly to your FastAPI origin, e.g. http://127.0.0.1:8010
# NEXT_PUBLIC_API_URL=http://127.0.0.1:8010
# Next dev proxy target (see frontend/next.config.js)
BACKEND_PROXY_URL=http://127.0.0.1:8010
# Set to 1 only if you intentionally run AOE on :8000 and need the browser to call it directly.
# NEXT_PUBLIC_API_FORCE_URL=1
# Optional: ArangoDB web UI / Graph Visualizer (for deep links from the app)
NEXT_PUBLIC_ARANGO_URL=http://localhost:8529
NEXT_PUBLIC_ARANGO_DB=OntoExtract

# -- Extraction Defaults -------------------------------------------------------
EXTRACTION_PASSES=3
EXTRACTION_CONSISTENCY_THRESHOLD=2
EXTRACTION_CONFIDENCE_MIN=0.6
# Parallel extractor LLM calls (default 40). Use 3–8 on OpenAI Tier-1 to avoid 429 TPM limits.
# LLM_EXTRACTION_MAX_CONCURRENCY=5

# -- Entity Resolution Defaults ------------------------------------------------
ER_VECTOR_SIMILARITY_THRESHOLD=0.85
ER_VECTOR_WEIGHT=0.6
ER_TOPO_WEIGHT=0.4

# -- Admin / Development -------------------------------------------------------
# Set to true to enable /api/v1/admin/reset endpoints (dev/demo only)
ALLOW_SYSTEM_RESET=false
